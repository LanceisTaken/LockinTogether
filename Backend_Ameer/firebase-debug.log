[debug] [2026-04-11T14:29:15.158Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/lockintogether-9c05f:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function isLoggedIn() {\n      return request.auth != null;\n    }\n    \n    function getBoardRole(boardId) {\n  \t\treturn get(/databases/$(database)/documents/boardMembers/$(request.auth.uid + '_' + boardId)).data.role;\n\t\t}\n\n    function isBoardOwner(boardId) {\n      return getBoardRole(boardId) == 'owner';\n    }\n\n    function isBoardAdmin(boardId) {\n      return getBoardRole(boardId) in ['owner', 'admin'];\n    }\n\n    function isBoardMember(boardId) {\n      return getBoardRole(boardId) in ['owner', 'admin', 'member'];\n    }\n\n    function isAppAdmin() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // Users collection\n    match /users/{userId} {\n      allow read: if isLoggedIn();\n      allow create: if request.auth.uid == userId;\n      allow update: if request.auth.uid == userId || isAppAdmin();\n      allow delete: if isAppAdmin();\n    }\n\n    // Boards collection\n    match /boards/{boardId} {\n      allow read: if isLoggedIn() && isBoardMember(boardId);\n      allow create: if isLoggedIn();\n      allow update: if isLoggedIn() && isBoardAdmin(boardId);\n      allow delete: if isLoggedIn() && isBoardOwner(boardId);\n    }\n\n    // BoardMembers collection\n    match /boardMembers/{memberId} {\n      allow read: if isLoggedIn();\n      allow create: if isLoggedIn() && isBoardAdmin(request.resource.data.boardId);\n      allow update: if isLoggedIn() && isBoardOwner(resource.data.boardId);\n      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);\n    }\n\n    // Tasks collection\n    match /tasks/{taskId} {\n      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);\n      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);\n      allow update: if isLoggedIn() && isBoardMember(resource.data.boardId);\n      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);\n    }\n\n    // Attachments collection\n    match /attachments/{attachmentId} {\n      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);\n      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);\n      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);\n    }\n\n    // ActivityLog collection\n    match /activityLog/{logId} {\n      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);\n      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);\n      allow update, delete: if false; // Logs are immutable\n    }\n\n    // Notifications collection\n    match /notifications/{notificationId} {\n      allow read: if isLoggedIn() && resource.data.recipientId == request.auth.uid;\n      allow create: if isLoggedIn() && request.resource.data.senderId == request.auth.uid;\n      allow update: if isLoggedIn() && resource.data.recipientId == request.auth.uid;\n    }\n  }\n}"}]}}
