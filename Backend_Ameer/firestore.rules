rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isLoggedIn() {
      return request.auth != null;
    }
    
    function getBoardRole(boardId) {
  		return get(/databases/$(database)/documents/boardMembers/$(request.auth.uid + '_' + boardId)).data.role;
		}

    function isBoardOwner(boardId) {
      return getBoardRole(boardId) == 'owner';
    }

    function isBoardAdmin(boardId) {
      return getBoardRole(boardId) in ['owner', 'admin'];
    }

    function isBoardMember(boardId) {
      return getBoardRole(boardId) in ['owner', 'admin', 'member'];
    }

    function isAppAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAppAdmin();
      allow delete: if isAppAdmin();
    }

    // Boards collection
    match /boards/{boardId} {
      allow read: if isLoggedIn() && isBoardMember(boardId);
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && isBoardAdmin(boardId);
      allow delete: if isLoggedIn() && isBoardOwner(boardId);
    }

    // BoardMembers collection
    match /boardMembers/{memberId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && isBoardAdmin(request.resource.data.boardId);
      allow update: if isLoggedIn() && isBoardOwner(resource.data.boardId);
      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);
      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);
      allow update: if isLoggedIn() && isBoardMember(resource.data.boardId);
      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);
    }

    // Attachments collection
    match /attachments/{attachmentId} {
      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);
      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);
      allow delete: if isLoggedIn() && isBoardAdmin(resource.data.boardId);
    }

    // ActivityLog collection
    match /activityLogs/{logId} {
      allow read: if isLoggedIn() && isBoardMember(resource.data.boardId);
      allow create: if isLoggedIn() && isBoardMember(request.resource.data.boardId);
      allow update, delete: if false; // Logs are immutable
    }
  }
}