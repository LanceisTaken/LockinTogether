rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isBoardMember(boardId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/boardMembers/$(request.auth.uid + "_" + boardId));
    }

    function isBoardAdmin(boardId) {
      let memberDoc = get(/databases/$(database)/documents/boardMembers/$(request.auth.uid + "_" + boardId));
      return isAuthenticated() &&
        memberDoc != null &&
        (memberDoc.data.role == "owner" || memberDoc.data.role == "admin");
    }

    // ── Users Collection ──────────────────────────────────
    // Any authenticated user can read any profile (needed for member avatars/names).
    // Writes are handled by Cloud Functions only.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Boards Collection ─────────────────────────────────
    match /boards/{boardId} {
      allow read: if isBoardMember(boardId);
      allow write: if false;
    }

    // ── BoardMembers Collection ───────────────────────────
    match /boardMembers/{memberId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Tasks Collection ──────────────────────────────────
    // Authenticated users can read (membership checked at query level).
    // Writes handled by Cloud Functions only.
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Attachments Collection ────────────────────────────
    match /attachments/{attachmentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Activity Log Collection ───────────────────────────
    match /activityLog/{logId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Notifications Collection ──────────────────────────
    // Users can read their own notifications and create notifications for others.
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.recipientId == request.auth.uid;
    }
  }
}
